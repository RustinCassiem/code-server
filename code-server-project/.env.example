# Environment Configuration for Advanced Code Server

# Application Settings
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=codeserver
DB_PASSWORD=password
DB_NAME=codeserver
DATABASE_URL=postgresql://codeserver:password@localhost:5432/codeserver
DB_SSL=false
DB_LOGGING=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0
REDIS_KEY_PREFIX=codeserver:

# JWT and Session Configuration
JWT_SECRET=your_jwt_secret_change_in_production_make_it_very_long_and_random
SESSION_SECRET=your_session_secret_change_in_production_make_it_very_long_and_random
TOKEN_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH2_CLIENT_ID=your_oauth2_client_id
OAUTH2_CLIENT_SECRET=your_oauth2_client_secret
OAUTH2_AUTH_URL=https://your-provider.com/oauth/authorize
OAUTH2_TOKEN_URL=https://your-provider.com/oauth/token
OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Code Server Configuration
CODE_SERVER_BASE_URL=http://localhost
CODE_SERVER_PASSWORD=your_code_server_password
PORT_RANGE_START=8080
PORT_RANGE_END=8180
DEFAULT_TIMEOUT=1800
MAX_INSTANCES=100

# Docker Configuration
DOCKER_NETWORK=code-server-network
DOCKER_REGISTRY_URL=docker.io
DEFAULT_DOCKER_IMAGE=codercom/code-server:latest
VOLUME_PATH=/workspaces
DOCKER_SOCKET=/var/run/docker.sock

# Security Configuration
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=8
REQUIRE_TWO_FACTOR=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
MAX_FILE_SIZE=100
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@codeserver.dev

# Storage Configuration
STORAGE_PROVIDER=local
STORAGE_BUCKET=codeserver-files
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_ENDPOINT=http://localhost:9000

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_AUDIT_LOG=true

# Feature Flags
ENABLE_COLLABORATION=true
ENABLE_FILE_SHARING=true
ENABLE_TERMINAL_SHARING=true
ENABLE_LIVE_SHARE=true
ENABLE_EXTENSION_MARKETPLACE=true
ENABLE_GIT_INTEGRATION=true

# Development Settings (remove in production)
DEBUG=codeserver:*
VERBOSE_LOGGING=false
