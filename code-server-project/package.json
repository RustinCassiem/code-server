{
  "name": "advanced-code-server",
  "version": "1.0.0",
  "description": "Enterprise-grade code server with VS Code integration, authentication, and collaboration features",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker build -t advanced-code-server .",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f",
    "migrate": "ts-node src/migrations/migrate.ts",
    "seed": "ts-node src/seeders/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-rate-limit": "^6.10.0",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth2": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.8",
    "ioredis": "^5.3.2",
    "winston": "^3.10.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "rate-limiter-flexible": "^2.4.2",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "sequelize": "^6.32.1",
    "pg": "^8.11.3",
    "sqlite3": "^5.1.6",
    "dockerode": "^3.3.5",
    "node-cron": "^3.0.2",
    "compression": "^1.7.4",
    "express-slow-down": "^1.6.0",
    "express-brute": "^1.0.1",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "nodemailer": "^6.9.4",
    "crypto": "^1.0.1",
    "uuid": "^9.0.0",
    "jimp": "^0.22.10",
    "archiver": "^5.3.1",
    "simple-git": "^3.19.1",
    "sharp": "^0.32.5",
    "express-fileupload": "^1.4.0",
    "ws": "^8.13.0",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.7",
    "express-prometheus-middleware": "^1.2.0",
    "prom-client": "^14.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/passport": "^1.0.12",
    "@types/passport-local": "^1.0.35",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/multer": "^1.4.7",
    "@types/compression": "^1.7.2",
    "@types/nodemailer": "^6.4.9",
    "@types/uuid": "^9.0.2",
    "@types/archiver": "^5.3.2",
    "@types/ws": "^8.5.5",
    "@types/speakeasy": "^2.0.7",
    "@types/qrcode": "^1.5.1",
    "typescript": "^5.1.6",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "jest": "^29.6.2",
    "@types/jest": "^29.5.4",
    "ts-jest": "^29.1.1",
    "eslint": "^8.47.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/advanced-code-server.git"
  },
  "keywords": [
    "code-server",
    "vscode",
    "authentication",
    "collaboration",
    "containers",
    "docker",
    "typescript",
    "enterprise"
  ],
  "author": "Your Name",
  "license": "MIT"
}